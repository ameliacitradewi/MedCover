{
  "model_file": "insurance_model.mlmodel",
  "model_version": "1.0.0",
  "target_space": "log1p(charges)",
  "postprocess": "expm1()  \u2014 wajib dilakukan di Swift sebelum ditampilkan",
  "input_features": [
    {
      "name": "age",
      "type": "Float32",
      "source": "raw input"
    },
    {
      "name": "age_squared",
      "type": "Float32",
      "source": "age * age  \u2014 hitung di Swift"
    },
    {
      "name": "bmi",
      "type": "Float32",
      "source": "raw input, setelah di-clip"
    },
    {
      "name": "children",
      "type": "Float32",
      "source": "raw input"
    },
    {
      "name": "smoker_encoded",
      "type": "Float32",
      "source": "1 jika smoker, 0 jika tidak"
    },
    {
      "name": "smoker_bmi",
      "type": "Float32",
      "source": "smoker_encoded * bmi  \u2014 hitung di Swift"
    }
  ],
  "preprocessing_steps_swift": [
    "1. bmi = min(max(bmi, 13.67), 47.31)  // IQR clip \u2014 gunakan nilai ini",
    "2. age_squared = age * age",
    "3. smoker_bmi  = smoker_encoded * bmi  // gunakan bmi SETELAH di-clip",
    "4. Susun input sesuai urutan input_features di atas",
    "5. Jalankan model.prediction()",
    "6. output = exp(model.output) - 1  // expm1 untuk balik ke dollar"
  ],
  "bmi_clip": {
    "lower": 13.67,
    "upper": 47.31
  },
  "test_metrics": {
    "R2": 0.8963,
    "RMSE": 4364.21
  }
}